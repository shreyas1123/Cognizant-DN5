<configuration>
    <!-- Define a CONSOLE appender that prints to stdout -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Standard logging pattern containing timestamp, thread name, log level, class name, and message -->
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Configure the root logger to output at INFO level or higher to the CONSOLE appender -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>
